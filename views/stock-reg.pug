doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NYONDO Stock Registration
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/stock.css')
.container.my-5
  .form-card.card
    .card-header Stock Registration Form
    .card-body
      form(action='/stockreg' method='post')
        // Product Name
        .mb-3
          label.form-label(for='productName') Product Name
          input#productName.form-control(type='text' name='productname' placeholder='Enter product name')
        // Product Code
        .mb-3
          label.form-label(for='productCode') Product Code
          input#productCode.form-control(type='text' name='productcode' placeholder='Enter product code')
        // Quantity
        .mb-3
          label.form-label(for='quantity') Quantity
          input#quantity.form-control(type='number' name='quantity' placeholder='Enter quantity')
        // Supplier
        .mb-3
          label.form-label(for='supplier') Supplier
          input#supplier.form-control(type='text' name='supplier' placeholder='Enter supplier name')
        // Price
        .mb-3
          label.form-label(for='price') Unit Price (UGX)
          input#price.form-control(type='number' name='unitprice' placeholder='Enter unit price')
        // Date
        .mb-3
          label.form-label(for='date') Date Added
          input#date.form-control(type='date' name='dateadded')
        // Submit
        button.btn.btn-gold(type='submit') Register Stock
// Bootstrap JS
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
